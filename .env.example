# ─────────────────────────────────────────────────────────────
# Parekh Family — environment variables
# Copy to `.env.local` for local dev. Set the same in Vercel.
# ─────────────────────────────────────────────────────────────

# App
APP_URL=http://localhost:3000
APP_NAME="Parekh Family"
# Random 32+ char secret for signing session JWTs (openssl rand -base64 32)
SESSION_SECRET=

# ── Database (Neon serverless Postgres) ──
# postgres://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# ── WhatsApp Cloud API (Meta) ──
# From Meta App > WhatsApp > API Setup
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
# The name of your approved AUTHENTICATION template used to send OTP codes
WHATSAPP_OTP_TEMPLATE_NAME=otp_login
# Locale of that template, e.g. en_US
WHATSAPP_OTP_TEMPLATE_LANG=en_US
# A verify token YOU choose; set the same value in the Meta webhook config
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
# Optional: Meta App Secret to validate webhook signatures (X-Hub-Signature-256)
WHATSAPP_APP_SECRET=

# ── Text generation (Claude) ──
# Option A: Amazon Bedrock API key (bearer token). If set, this takes precedence.
AWS_BEARER_TOKEN_BEDROCK=
# Region where Bedrock model access is enabled. On Vercel use BEDROCK_REGION
# (AWS_REGION is reserved by Lambda); locally either works.
AWS_REGION=us-east-1
BEDROCK_REGION=us-east-1
# Bedrock model id (account/region-specific; enable model access in the Bedrock console).
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0
# Option B: Anthropic direct API key (used only if the Bedrock token is absent).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Image generation provider ──
# One of: "stub" (no external calls, returns placeholder), later "firefly" | "replicate"
IMAGE_PROVIDER=stub
# ── Video generation provider (Phase 2) ──
# One of: "stub" (returns a sample clip), later "replicate" | "firefly"
VIDEO_PROVIDER=stub
# REPLICATE_API_TOKEN=
# FIREFLY_CLIENT_ID=
# FIREFLY_CLIENT_SECRET=

# ── Vercel Blob (photo storage) ──
# Created automatically when you add Blob storage in the Vercel dashboard
BLOB_READ_WRITE_TOKEN=

# ── Inngest (orchestration) ──
# From the Inngest dashboard (or leave blank for local dev with `npx inngest-cli dev`)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ── Email (password reset, via Resend) ──
# Without a key, reset links are shown in the API response (dev fallback).
RESEND_API_KEY=
RESEND_FROM="Parekh Family <onboarding@resend.dev>"

# ── GIF source (Giphy) ──
# Free key from developers.giphy.com. Without it, GIF wishes generate text only.
GIPHY_API_KEY=

# ── Web Push (PWA notifications) ──
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# ── Behaviour tuning ──
# Days before a special day to start the approval flow
APPROVAL_LEAD_DAYS=3
# Secret used to protect the cron endpoint (Vercel sets Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=
